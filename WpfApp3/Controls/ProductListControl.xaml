<UserControl x:Class="WpfApp3.Controls.ProductListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfApp3.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Loaded="ProductListControl_Loaded">
    <Grid>
        
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" >
            <ItemsControl x:Name="ProductsItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate >
                    <DataTemplate>
                        <Border Width="Auto" Cursor="Hand" MouseLeftButtonUp="ProductCard_MouseLeftButtonUp" MouseRightButtonUp="ProductCard_MouseRightButtonUp">

                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="White" />

                                        <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasBigDiscount}" Value="True">
                                            <Setter Property="Background" Value="#2E8B57" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsOutOfStock}" Value="True">
                                            <Setter Property="Background" Value="LightBlue" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <StackPanel Margin="30" Orientation="Horizontal" ToolTip="ЛКМ: выбрать товар | ПКМ: редактировать">
                                <StackPanel Margin="10 0">
                                    <Image Width="100" Height="100" Stretch="Uniform" Source="{Binding ProductImagePath}" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="{Binding ProductName}"/>
                                    <TextBlock Text="{Binding Description, StringFormat=Описание: {0}}"/>
                                    <TextBlock Text="{Binding Manufacturer.ManufacturerName, StringFormat=Производитель: {0}}"/>
                                    <TextBlock Text="{Binding Supplier.SupplierName, StringFormat=Поставщик: {0}}"/>
                                    <TextBlock Text="{Binding Price, StringFormat=Цена: {0} руб.}" Visibility="{Binding OldPriceVisibility}"/>
                                    <StackPanel Visibility="{Binding DiscountedPriceVisibility}">
                                        <TextBlock Text="{Binding Price, StringFormat=Цена: {0} руб.}" Foreground="Red" TextDecorations="Strikethrough"/>
                                        <TextBlock Text="{Binding FinalPrice, StringFormat=Цена: {0} руб.}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Units.UnitsName, StringFormat=Единица измерения: {0}}"/>
                                    <TextBlock Text="{Binding Quantity, StringFormat=Количество: {0}}"/>
                                    <TextBlock Text="{Binding Discount, StringFormat=Скидка: {0} %}"/>
                                </StackPanel>
                               
                                
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
