<Window x:Class="WpfApp3.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар"
        Height="600"
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <ScrollViewer>
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel x:Name="IdPanel" Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="ID товара"/>
                <TextBox x:Name="IdBox" IsReadOnly="True"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,0,0,10">
                <TextBlock Text="Артикул"/>
                <TextBox x:Name="ArticleBox"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,0,10">
                <TextBlock Text="Фото товара"/>
                <Image x:Name="PreviewImage"
                       Width="140"
                       Height="100"
                       Stretch="Uniform"
                       Margin="0,5,0,5"/>
                <Button Content="Выбрать фото"
                        Width="120"
                        Click="SelectPhotoButton_Click"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,0,0,10">
                <TextBlock Text="Наименование"/>
                <TextBox x:Name="ProductNameBox"/>
            </StackPanel>

            <StackPanel Grid.Row="4" Margin="0,0,0,10">
                <TextBlock Text="Категория"/>
                <ComboBox x:Name="CategoryBox"/>
            </StackPanel>

            <StackPanel Grid.Row="5" Margin="0,0,0,10">
                <TextBlock Text="Описание"/>
                <TextBox x:Name="DescriptionBox" Height="60" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Grid.Row="6" Margin="0,0,0,10">
                <TextBlock Text="Производитель"/>
                <ComboBox x:Name="ManufacturerBox"/>
            </StackPanel>

            <StackPanel Grid.Row="7" Margin="0,0,0,10">
                <TextBlock Text="Поставщик"/>
                <ComboBox x:Name="SupplierBox"/>
            </StackPanel>

            <StackPanel Grid.Row="8" Margin="0,0,0,10">
                <TextBlock Text="Цена"/>
                <TextBox x:Name="PriceBox"/>
            </StackPanel>

            <StackPanel Grid.Row="9" Margin="0,0,0,10">
                <TextBlock Text="Единица измерения"/>
                <ComboBox x:Name="UnitBox"/>
            </StackPanel>

            <StackPanel Grid.Row="10" Margin="0,0,0,10">
                <TextBlock Text="Количество на складе"/>
                <TextBox x:Name="QuantityBox"/>
            </StackPanel>

            <StackPanel Grid.Row="11" Margin="0,0,0,20">
                <TextBlock Text="Скидка"/>
                <TextBox x:Name="DiscountBox"/>
            </StackPanel>

            <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Сохранить"
                        Width="100"
                        Height="30"
                        Margin="0,0,10,0"
                        Click="SaveButton_Click"/>

                <Button Content="Отмена"
                        Width="100"
                        Height="30"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>