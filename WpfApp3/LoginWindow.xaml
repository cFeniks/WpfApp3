<Window x:Class="WpfApp3.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp3"
        mc:Ignorable="d"
        Title="Вход в систему" MinHeight="450" MinWidth="900">
    <Grid>
        <StackPanel Margin="250,50,250,50">
            <TextBlock TextWrapping="Wrap" Text="Вход" FontSize="24" FontWeight="Bold" TextAlignment="Center" />
            <StackPanel Margin="0 30 0 0">
                <TextBlock TextWrapping="Wrap" Text="Логин" Height="20" Width="380"/>
                <TextBox x:Name="LoginTextBox" TextWrapping="Wrap" Width="380" Height="30"/>
            </StackPanel>
            <StackPanel Margin="0 30 0 0">
                <TextBlock TextWrapping="Wrap" Text="Пароль" Height="20" Width="380"/>
                <PasswordBox x:Name="PasswordBox" Width="380" Height="30"/>
            </StackPanel>

            <StackPanel Margin="0 30 0 0">
                <TextBlock x:Name="ErrorTextBlock" TextWrapping="Wrap" Width="380"/>
                <Button Margin="0 0 0 5" Height="30"  Content="Вход" Click="LoginButton_Click" Width="380"/>
                <Button Height="30" Content="Продолжить как гость" Click="GuestButton_Click" Width="380"/>
            </StackPanel>


        </StackPanel>
    </Grid>
</Window>
